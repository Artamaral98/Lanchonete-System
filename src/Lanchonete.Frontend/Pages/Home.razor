@page "/"
@using Microsoft.AspNetCore.Authorization
@using Lanchonete.Frontend.Models
@using Lanchonete.Frontend.Services
@attribute [Authorize]

<div class="animate-fade-in-up">
    <div class="glass-card home-card">
        <div class="header-section">
            <div class="logo-icon-small">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
            </div>
            <div>
                <h2>Bem-vindo à Lanchonete</h2>
                <p class="subtitle">Gerencie seus pedidos com facilidade.</p>
            </div>
        </div>

        <div class="divider">
            <div class="divider-line"></div>
        </div>

        <div class="content-section">
            @if (_isLoading)
            {
                <p class="status-msg">Carregando pedidos...</p>
            }
            else if (_erroMensagem != null)
            {
                <p class="status-msg error-msg">@_erroMensagem</p>
            }
            else if (_pedidos.Count == 0)
            {
                <p class="status-msg">Nenhum pedido encontrado.</p>
            }
            else
            {
                <div class="orders-list">
                    @foreach (var pedido in _pedidos)
                    {
                        <div class="order-item">
                            <div class="order-row-header">
                                <span class="order-id">#@(pedido.Id.ToString().Length > 8 ? pedido.Id.ToString().Substring(0, 8) : pedido.Id.ToString())</span>
                                <span class="order-date">@pedido.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                                <span class="order-total">Total: @pedido.Total.ToString("C")</span>
                            </div>
                            <div class="order-items-list">
                                @if (pedido.Itens != null)
                                {
                                    @foreach (var item in pedido.Itens)
                                    {
                                        <div class="order-item-row">
                                            <span class="item-qty">@item.Quantidade x</span>
                                            <span class="item-name">@item.NomeItem</span>
                                            <span class="item-subtotal">@item.SubtotalItem.ToString("C")</span>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private PedidoService PedidoService { get; set; } = default!;

    private List<PedidoOutputDto> _pedidos = [];
    private bool _isLoading = true;
    private string? _erroMensagem;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            _isLoading = true;
            _erroMensagem = null;

            // JS Interop garantidamente disponível aqui
            var authState = await AuthStateTask;
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                _erroMensagem = "Usuário não autenticado.";
                return;
            }

            var response = await PedidoService.GetPedidos();

            if (response.Erros?.Count > 0)
                _erroMensagem = string.Join(", ", response.Erros);
            else
                _pedidos = response.Dados ?? [];
        }
        catch (Exception ex)
        {
            _erroMensagem = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged(); // necessário pois OnAfterRender não re-renderiza automaticamente
        }
    }
}