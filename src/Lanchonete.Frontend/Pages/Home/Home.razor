@page "/"
@using Microsoft.AspNetCore.Authorization
@using Lanchonete.Frontend.Models
@using Lanchonete.Frontend.Services
@using Lanchonete.Frontend.Components.Pedidos
@attribute [Authorize]

<div class="animate-fade-in-up">
    <div class="glass-card home-card">
        <div class="header-section">
            <div class="welcome-section">
                <div class="logo-icon-small">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                    </svg>
                </div>
                <div>
                    <h2>Bem-vindo à Good Burger</h2>
                    <p class="subtitle">Gerencie seus pedidos com facilidade.</p>
                </div>
            </div>

            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" 
                       placeholder="Busque o pedido..." 
                       @bind="_searchQuery" 
                       @bind:event="oninput" />
            </div>
        </div>

        <div class="divider">
            <div class="divider-line"></div>
        </div>

        <div class="content-section">
            @if (_isLoading)
            {
                <p class="status-msg">Carregando pedidos...</p>
            }
            else if (_erroMensagem != null)
            {
                <p class="status-msg error-msg">@_erroMensagem</p>
            }
            else if (_pedidos.Count == 0)
            {
                <p class="status-msg">Nenhum pedido encontrado @(string.IsNullOrEmpty(_searchQuery) ? "" : $"para '{_searchQuery}'").</p>
            }
            else
            {
                <div class="orders-scroll-container">
                    <div class="orders-list">
                        @foreach (var pedido in PedidosPaginados)
                        {
                            <div class="order-item">
                                <div class="order-row-header">
                                    <span class="order-id">#@pedido.Codigo</span>
                                    <span class="order-date">@pedido.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span>
                                    
                                    <div class="order-actions">
                                        <button class="action-btn edit" title="Editar Pedido" @onclick="() => IrParaEditar(pedido.Id)">
                                            <span class="bi bi-pencil-fill"></span>
                                        </button>
                                        <button class="action-btn delete" title="Excluir Pedido" @onclick="() => ConfirmarExclusao(pedido.Id)">
                                            <span class="bi bi-trash-fill"></span>
                                        </button>
                                    </div>

                                    <span class="order-total">@pedido.Total.ToString("C")</span>
                                </div>
                                <div class="order-items-list">
                                    @if (pedido.Itens != null)
                                    {
                                        @foreach (var item in pedido.Itens)
                                        {
                                            <div class="order-item-row">
                                                <span class="item-qty">@item.Quantidade x</span>
                                                <span class="item-name">@item.NomeItem</span>
                                                <span class="item-subtotal">@item.SubtotalItem.ToString("C")</span>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (TotalPaginas > 1)
                {
                    <Paginacao 
                        PaginaAtual="_paginaAtual" 
                        TotalPaginas="TotalPaginas" 
                        OnPaginaAlterada="MudarPagina" />
                }
            }
        </div>
    </div>
</div>

<EditarPedidoModal 
    IsVisible="_isModalVisible" 
    PedidoId="_pedidoIdParaEditar" 
    OnClose="() => _isModalVisible = false"
    OnSuccess="RecarregarPedidos" />

<ConfirmacaoModal
    IsVisible="_isDeleteModalVisible"
    IsProcessando="_isExcluindo"
    OnCancelar="() => _isDeleteModalVisible = false"
    OnConfirmar="ExecutarExclusao" />

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private PedidoService PedidoService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ToastService ToastService { get; set; } = default!;

    private List<PedidoOutputDto> _pedidos = [];
    private bool _isLoading = true;
    private string? _erroMensagem;
    private string _searchQuery = "";

    private List<PedidoOutputDto> PedidosFiltrados => string.IsNullOrWhiteSpace(_searchQuery)
        ? _pedidos
        : _pedidos.Where(p => p.Codigo.ToString().Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)).ToList();

    private int _paginaAtual = 1;
    private const int ItensPorPagina = 8;
    private int TotalPaginas => (int)Math.Ceiling((double)PedidosFiltrados.Count / ItensPorPagina);
    private IEnumerable<PedidoOutputDto> PedidosPaginados => PedidosFiltrados
        .Skip((_paginaAtual - 1) * ItensPorPagina)
        .Take(ItensPorPagina);

    // Estado dos Modais
    private bool _isModalVisible;
    private Guid _pedidoIdParaEditar;
    
    private bool _isDeleteModalVisible;
    private Guid _pedidoIdParaExcluir;
    private bool _isExcluindo;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await RecarregarPedidos();
    }

    private async Task RecarregarPedidos()
    {
        try
        {
            _isLoading = true;
            _erroMensagem = null;
            StateHasChanged();

            var authState = await AuthStateTask;
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                _erroMensagem = "Usuário não autenticado.";
                return;
            }

            var response = await PedidoService.GetPedidos();

            if (response.Erros?.Count > 0)
                _erroMensagem = string.Join(", ", response.Erros);
            else
                _pedidos = response.Dados?.OrderByDescending(p => p.DataCriacao).ToList() ?? [];
            
            _paginaAtual = 1; 
        }
        catch (Exception ex)
        {
            _erroMensagem = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void MudarPagina(int novaPagina)
    {
        _paginaAtual = novaPagina;
        StateHasChanged();
    }

    private void IrParaEditar(Guid id)
    {
        _pedidoIdParaEditar = id;
        _isModalVisible = true;
    }

    private void ConfirmarExclusao(Guid id)
    {
        _pedidoIdParaExcluir = id;
        _isDeleteModalVisible = true;
    }

    private async Task ExecutarExclusao()
    {
        _isExcluindo = true;
        try
        {
            var response = await PedidoService.RemoverPedido(_pedidoIdParaExcluir);
            
            if (response)
            {
                ToastService.ShowSuccess("Pedido removido com sucesso.");
                _pedidos.RemoveAll(p => p.Id == _pedidoIdParaExcluir);
                _isDeleteModalVisible = false;
                
                if (_paginaAtual > TotalPaginas && _paginaAtual > 1) 
                    _paginaAtual = TotalPaginas;
            }
            else
            {
                ToastService.ShowError("Erro ao remover o pedido.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Erro de conexão: " + ex.Message);
        }
        finally
        {
            _isExcluindo = false;
            StateHasChanged();
        }
    }
}
