<div class="paginacao-container">
    <button class="pag-btn" disabled="@(PaginaAtual == 1)" @onclick="() => MudarPagina(PaginaAtual - 1)">
        <i class="bi bi-chevron-left"></i>
    </button>

    @for (int i = 1; i <= TotalPaginas; i++)
    {
        var p = i;
        <button class="pag-btn @(p == PaginaAtual ? "active" : "")" @onclick="() => MudarPagina(p)">
            @p
        </button>
    }

    <button class="pag-btn" disabled="@(PaginaAtual == TotalPaginas)" @onclick="() => MudarPagina(PaginaAtual + 1)">
        <i class="bi bi-chevron-right"></i>
    </button>
</div>

@code {
    [Parameter] public int PaginaAtual { get; set; } = 1;
    [Parameter] public int TotalPaginas { get; set; }
    [Parameter] public EventCallback<int> OnPaginaAlterada { get; set; }

    private async Task MudarPagina(int novaPagina)
    {
        if (novaPagina >= 1 && novaPagina <= TotalPaginas)
        {
            await OnPaginaAlterada.InvokeAsync(novaPagina);
        }
    }
}
