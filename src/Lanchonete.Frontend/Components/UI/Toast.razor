@using Lanchonete.Frontend.Services
@implements IDisposable

@if (_toasts.Any())
{
    <div class="toast-container">
        @foreach (var toast in _toasts)
        {
            <div class="glass-toast @toast.Level.ToString().ToLower() animate-fade-in-up">
                <div class="toast-content">
                    <span class="toast-icon"></span>
                    <span class="toast-message">@toast.Message</span>
                </div>
                <button class="toast-close" @onclick="() => RemoveToast(toast)">×</button>
            </div>
        }
    </div>
}

@code {
    [Inject] private ToastService ToastService { get; set; } = default!;
    private List<ToastModel> _toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += HandleShow;
    }

    private void HandleShow(string message, ToastLevel level)
    {
        var toast = new ToastModel { Message = message, Level = level };
        _toasts.Add(toast);
        StateHasChanged();

        // Auto remove após 5 segundos
        Task.Delay(5000).ContinueWith(_ => RemoveToast(toast));
    }

    private void RemoveToast(ToastModel toast)
    {
        _toasts.Remove(toast);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ToastService.OnShow -= HandleShow;
    }

    private class ToastModel
    {
        public string Message { get; set; } = "";
        public ToastLevel Level { get; set; }
    }
}
